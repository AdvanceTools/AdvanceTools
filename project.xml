<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- ========================= -->
	<!-- BASIC INFO -->
	<!-- ========================= -->
	<app title="AdvanceTools"
		 file="advancetools"
		 main="Main"
		 version="1.0.0"
		 company="AdvanceTools Team" />

	<meta title="AdvanceTools"
		  package="com.advancetools.engine"
		  version="1.0.0"
		  company="AdvanceTools" />

	<!-- ========================= -->
	<!-- WINDOW -->
	<!-- ========================= -->
	<window width="1280"
			height="720"
			fps="60"
			background="#0d0d1a"
			orientation="landscape"
			resizable="true"
			vsync="true" />

	<!-- ========================= -->
	<!-- SOURCE -->
	<!-- ========================= -->
	<source path="source" />

	<!-- ========================= -->
	<!-- LIBRARIES -->
	<!-- ========================= -->
	<haxelib name="lime" />
	<haxelib name="openfl" />
 <haxelib name="hxcpp" />

	<!-- ========================= -->
	<!-- TARGETS -->
	<!-- ========================= -->
	<target name="html5" />
	<target name="android" />

	<!-- ========================= -->
	<!-- HTML5 SETTINGS -->
	<!-- ========================= -->
	<define name="webgl" if="html5" />
	<define name="canvas" if="html5" />
	<define name="dom" if="html5" />
	<define name="minify" if="html5" />
	<define name="source-map" if="debug" />

	<!-- ========================= -->
	<!-- ANDROID SETTINGS -->
	<!-- ========================= -->
	<android target-sdk-version="33"
			 min-sdk-version="21"
			 install-location="auto" />

	<!-- Permissões básicas -->
	<android-permission name="android.permission.INTERNET" />
	<android-permission name="android.permission.ACCESS_NETWORK_STATE" />

	<!-- Tela cheia -->
	<android fullscreen="true" />

	<!-- ========================= -->
	<!-- PERFORMANCE -->
	<!-- ========================= -->
	<define name="allow-high-dpi" />
	<define name="fast-mem" />

	<!-- ========================= -->
	<!-- BUILD MODES -->
	<!-- ========================= -->
	<set name="BUILD_TYPE" value="release" unless="debug" />
	<set name="BUILD_TYPE" value="debug" if="debug" />

	<!-- ========================= -->
	<!-- CUSTOM FLAGS -->
	<!-- ========================= -->
	<define name="ADVANCED_TOOLS" />
	<define name="ENABLE_AI_MODULE" />
	<define name="ENABLE_UTILS" />

</project>